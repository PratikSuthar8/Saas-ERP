{
  "name": "backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "NODE_ENV=dev tsx watch src/server.ts",
    "dev:uat": "NODE_ENV=uat tsx watch src/server.ts",
    "dev:prod": "NODE_ENV=prod tsx watch src/server.ts",
    "build": "tsc --noEmitOnError false || true",
    "start": "NODE_ENV=prod node dist/server.js",
    "start:uat": "NODE_ENV=uat node dist/server.js",
    "start:prod": "NODE_ENV=prod node dist/server.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "handlebars": "^4.7.9",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "http-errors": "^2.0.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "mongoose": "^9.4.1",
    "nodemailer": "^8.0.5",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/jspdf": "^2.0.0",
    "@types/node": "^25.5.2",
    "@types/nodemailer": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
